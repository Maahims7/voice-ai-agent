# ============================================================
# .env.example — Environment Variables for Voice AI Agent
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables are optional — the agent works with defaults.
# ============================================================

# ---- Ollama Settings (local LLM) ----
# URL where Ollama is running (default: localhost)
OLLAMA_URL=http://localhost:11434

# Which Ollama model to use (must be pulled first)
# Options: llama3, mistral, phi3, llama3.2, codellama
OLLAMA_MODEL=llama3

# ---- Groq API (STT fallback only) ----
# Only needed if you toggle ON "Use Groq API for STT"
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
